# Agent Hub — environment variables
# Copy this file to .env and fill in your values.

# Login password (required in production)
HUB_PASSWORD=changeme

# HTTP port
PORT=4001

# OpenClaw root directory (auto-discovers workspace-* dirs)
OPENCLAW_ROOT=~/.openclaw

# Custom skills directory
AGENTS_SKILLS_ROOT=~/.agents/skills

# Path to config file (optional — auto-discovery works without it)
# CONFIG_PATH=./agent-hub.config.json

# Force auth even in dev mode
# HUB_AUTH=true

# Google Gemini API key for semantic skill search (optional)
# GEMINI_API_KEY=
